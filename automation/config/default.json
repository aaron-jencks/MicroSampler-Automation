{
    "harness": {
        "prefix": "harness",
        "executable": "harness",
        "target": "attack.c",
        "key_file": "keys.txt",
        "deployment_prefix": "deploy",
        "timeout": 60,
        "allowed_references": [
            "encryption_util.h",
            "error.h",
            "context.h"
        ]
    },
    "workbench": {
        "prefix": "workbench",
        "script": "workbench.sh",
        "data_directory": "data",
        "source": {
            "prefix": "source",
            "contents": {
                "bearssl": "../../../apps/bearssl-0.6/src"
            }
        }
    },
    "llm": {
        "model": "gpt-5.3-codex",
        "templates": {
            "instructions": "instructions-prompt.txt",
            "initial_message": "initial-prompt.txt",
            "stuck_message": "stuck-prompt.txt"
        },
        "api_key": "",
        "report_name": "conclusion.md"
    },
    "logging": {
        "prefix": "logs",
        "output": "v2_output.log"
    }
}