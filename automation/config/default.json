{
    "expected_conclusion": {
        "enabled": false,
        "is_constant": false,
        "manual_verify": false
    },
    "harness": {
        "prefix": "harness",
        "executable": "harness",
        "target": "attack.c",
        "key_file": "keys.txt",
        "deployment_prefix": "deploy",
        "timeout": 60,
        "allowed_references": [
            "encryption_util.h",
            "error.h",
            "context.h"
        ],
        "uut": {
            "prefix": "uut",
            "file": "wrapper.c"
        }
    },
    "workbench": {
        "prefix": "workbench",
        "script": "workbench.sh",
        "data_directory": "data",
        "source": {
            "prefix": "source",
            "contents": {
                "bearssl": "../apps/bearssl-0.6/src"
            }
        }
    },
    "llm": {
        "model": "gpt-5.3-codex",
        "templates": {
            "files": {
                "instructions": "prompts/instructions-prompt.txt",
                "initial_message": "prompts/initial-prompt.txt",
                "stuck_message": "prompts/stuck-prompt.txt",
                "wrong_conclusion_message": "prompts/wrong-conclusion.txt",
                "target_prompt": "prompts/target-prompt.txt"
            }
        },
        "api_key": "",
        "report_name": "conclusion.md"
    },
    "logging": {
        "prefix": "logs",
        "output": "v2_output.log"
    },
    "final_report": {
        "prefix": "final_report",
        "run_name": "undefined",
        "file": "final_report.html",
        "plots_prefix": "images",
        "clear_report_area": true
    }
}